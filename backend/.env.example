# --- Server ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# --- Storage ---
# Backend: `local` (filesystem) or `s3`. Leave blank to auto-pick based on
# whether AWS_ACCESS_KEY_ID + S3_BUCKET are set. Default in dev is `local`.
STORAGE_BACKEND=
LOCAL_STORAGE_DIR=./storage

# --- AWS S3 (only used when STORAGE_BACKEND=s3) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=ai-hiring-assistant
# Prefixes inside the bucket (also used as folder names by the local backend)
S3_RESUME_PREFIX=resumes/
S3_METADATA_PREFIX=metadata/
S3_SHORTLIST_KEY=shortlist/shortlist.json

# --- LLM ---
# anthropic | openai | gemini
LLM_PROVIDER=anthropic
LLM_MAX_RETRIES=3
LLM_TIMEOUT_MS=60000

# Anthropic (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (used when LLM_PROVIDER=gemini)
GEMINI_API_KEY=
# Free-tier daily quotas vary a lot by model:
#   gemini-2.5-flash       →    20 req/day  (very tight — easy to exhaust)
#   gemini-2.5-flash-lite  →  1000 req/day
#   gemini-2.0-flash       →  1500 req/day
#   gemini-2.0-flash-lite  →  1500 req/day  (recommended for dev)
GEMINI_MODEL=gemini-2.0-flash-lite

# --- Hiring rules ---
SHORTLIST_THRESHOLD=70

# --- SMTP (used by /api/send-email) ---
# Gmail: create an App Password (myaccount.google.com → Security → App passwords)
# and paste it as SMTP_PASS. Never use your real Gmail password here.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
